<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Prevent rewrite loop
    RewriteCond %{REQUEST_URI} !^/aprati_backend/public/
    
    # Don't rewrite if file/folder exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Redirect all requests to aprati_backend/public
    RewriteRule ^(.*)$ aprati_backend/public/$1 [L]
</IfModule>
