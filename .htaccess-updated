<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Route /storage/* requests to Laravel backend storage
    RewriteCond %{REQUEST_URI} ^/storage/
    RewriteRule ^storage/(.*)$ aprati_backend/public/storage/$1 [L,QSA]
    
    # Route /admin/* to /api/admin/* (admin routes are in api.php)
    RewriteCond %{REQUEST_URI} ^/admin/
    RewriteRule ^admin/(.*)$ aprati_backend/public/index.php [L,QSA,E=REQUEST_URI:/api/admin/$1]
    
    # Route /api/* requests to backend
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^api/(.*)$ aprati_backend/public/index.php [L,QSA]
    
    # Route direct API endpoint calls (without /api prefix) - rewrite to /api/*
    RewriteCond %{REQUEST_URI} ^/(hero-content|hero-image|information-sections|brands|products|header-settings|footer-settings|admin-profile-image|careers|management-posts|about)$
    RewriteRule ^(.*)$ /api/$1 [L,QSA]
</IfModule>
