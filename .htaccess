<IfModule mod_rewrite.c>
  Options +FollowSymLinks
  RewriteEngine On
  
  # 1. Map /storage requests directly to the physical storage folder
  # (This bypasses the need for 'php artisan storage:link' on the server)
  RewriteRule ^storage/(.*)$ api/storage/app/public/$1 [L]

  # 2. Standard SPA Routing (Nuxt)
  # If the requested file doesn't exist, send it to index.html
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
