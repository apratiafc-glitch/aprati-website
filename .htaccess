<IfModule mod_rewrite.c>
  Options +FollowSymLinks
  RewriteEngine On
  
  # 1. Map /storage requests directly to the new public assets folder
  # (This bypasses cPanel's 'storage' folder blocking)
  RewriteRule ^storage/(.*)$ api/public/live_assets/$1 [L]

  # 2. Standard SPA Routing (Nuxt)
  # If the requested file doesn't exist, send it to index.html
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
